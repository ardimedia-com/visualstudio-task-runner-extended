<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:vs="http://schemas.microsoft.com/visualstudio/extensibility/2022/xaml"
              xmlns:styles="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
              xmlns:colors="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0">
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Task tree -->
        <TreeView Grid.Row="0"
                  ItemsSource="{Binding TreeItems}"
                  Background="{DynamicResource {x:Static styles:VsBrushes.ToolWindowBackgroundKey}}"
                  BorderThickness="0"
                  Padding="0">
            <TreeView.ItemTemplate>
                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Margin="0,1,4,1">
                        <!-- Node icon -->
                        <vs:Image Source="{Binding Icon}"
                                  Width="16" Height="16"
                                  Margin="0,0,4,0"
                                  VerticalAlignment="Center" />

                        <!-- Task/Node name -->
                        <TextBlock Text="{Binding Name, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource {x:Static styles:VsBrushes.WindowTextKey}}" />

                        <!-- Metadata -->
                        <TextBlock Text="{Binding Metadata, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   Margin="4,0,0,0"
                                   FontSize="11"
                                   Foreground="{DynamicResource {x:Static styles:VsBrushes.GrayTextKey}}" />
                    </StackPanel>
                </HierarchicalDataTemplate>
            </TreeView.ItemTemplate>
            <TreeView.ItemContainerStyle>
                <Style TargetType="TreeViewItem">
                    <Setter Property="IsExpanded" Value="True" />
                    <Setter Property="Padding" Value="2,1" />
                    <Setter Property="BorderThickness" Value="0" />
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                    <Setter Property="FocusVisualStyle" Value="{x:Null}" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TreeViewItem">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- Item row: full-width background starting from left edge -->
                                    <Border x:Name="ItemBorder"
                                            Grid.Row="0"
                                            Background="Transparent"
                                            Padding="0,1"
                                            Margin="-200,0,0,0"
                                            SnapsToDevicePixels="True">
                                        <DockPanel x:Name="HeaderPanel" Margin="200,0,0,0" Background="Transparent">
                                            <!-- Right-click: select node + show context menu -->
                                            <vs:ExtensibilityUICommands.EventHandlers>
                                                <vs:EventHandlerCollection>
                                                    <vs:EventHandler Event="MouseRightButtonDown"
                                                                     Command="{Binding SelectCommand}"
                                                                     CommandParameter="{Binding Name}" />
                                                </vs:EventHandlerCollection>
                                            </vs:ExtensibilityUICommands.EventHandlers>
                                            <DockPanel.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="Start"
                                                              Command="{Binding StartCommand}"
                                                              CommandParameter="{Binding Name}"
                                                              IsEnabled="{Binding CanStart}" />
                                                    <MenuItem Header="Stop"
                                                              Command="{Binding StopCommand}"
                                                              CommandParameter="{Binding Name}"
                                                              IsEnabled="{Binding CanStop}" />
                                                    <Separator />
                                                    <MenuItem Header="Add to Group..."
                                                              IsEnabled="False" />
                                                </ContextMenu>
                                            </DockPanel.ContextMenu>
                                            <!-- Expand/collapse toggle -->
                                            <ToggleButton x:Name="Expander"
                                                          DockPanel.Dock="Left"
                                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                          ClickMode="Press"
                                                          Width="16" Height="16"
                                                          Margin="0,0,2,0"
                                                          Focusable="False"
                                                          VerticalAlignment="Center">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="ToggleButton">
                                                        <Border Background="Transparent" Padding="2">
                                                            <TextBlock x:Name="Arrow"
                                                                       Text="▸"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource {x:Static styles:VsBrushes.WindowTextKey}}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="Arrow" Property="Text" Value="▾" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>
                                            <!-- Content -->
                                            <ContentPresenter x:Name="PART_Header"
                                                              ContentSource="Header"
                                                              HorizontalAlignment="Stretch" />
                                        </DockPanel>
                                    </Border>

                                    <!-- Children -->
                                    <ItemsPresenter x:Name="ItemsHost"
                                                    Grid.Row="1"
                                                    Margin="16,0,0,0"
                                                    Visibility="Collapsed" />
                                </Grid>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsExpanded" Value="True">
                                        <Setter TargetName="ItemsHost" Property="Visibility" Value="Visible" />
                                    </Trigger>
                                    <Trigger Property="HasItems" Value="False">
                                        <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                                    </Trigger>
                                    <!-- Hover: highlight when mouse is over this item's header row (not children) -->
                                    <Trigger SourceName="HeaderPanel" Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background"
                                                Value="{DynamicResource {x:Static colors:EnvironmentColors.CommandBarMouseOverBackgroundGradientBrushKey}}" />
                                    </Trigger>
                                    <!-- Selected: full row highlight -->
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background"
                                                Value="{DynamicResource {x:Static colors:EnvironmentColors.CommandBarMenuItemMouseOverBrushKey}}" />
                                    </Trigger>
                                    <!-- Custom selection (via right-click SelectCommand) -->
                                    <DataTrigger Binding="{Binding IsNodeSelected}" Value="True">
                                        <Setter TargetName="ItemBorder" Property="Background"
                                                Value="{DynamicResource {x:Static colors:EnvironmentColors.CommandBarMenuItemMouseOverBrushKey}}" />
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TreeView.ItemContainerStyle>
        </TreeView>

        <!-- Status bar -->
        <Border Grid.Row="1"
                Background="{DynamicResource {x:Static styles:VsBrushes.CommandBarGradientBeginKey}}"
                Padding="6,3">
            <TextBlock Text="{Binding StatusText}"
                       FontSize="11"
                       Foreground="{DynamicResource {x:Static styles:VsBrushes.WindowTextKey}}" />
        </Border>
    </Grid>
</DataTemplate>
