<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="10">
        <TextBlock Text="Task Runner Extended"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,10" />
        <TextBlock Text="{Binding StatusText}"
                   Margin="0,0,0,10" />
        <TextBlock Text="Phase 1 spike: Validate TreeView, ContextMenu, Sidebar Placement, and Terminal API support in Remote UI."
                   TextWrapping="Wrap"
                   Opacity="0.6" />
    </StackPanel>
</DataTemplate>
